# InspectAI Environment Variables
# Copy this to .env and fill in your values

# ============================================
# GOOGLE AI — Choose ONE method:
# ============================================

# Option 1: API Key (Google AI Studio — easiest for development)
GOOGLE_API_KEY=your-gemini-api-key-here

# Option 2: Vertex AI (Google Cloud — for production)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ============================================
# GOOGLE CLOUD SERVICES
# ============================================

# Cloud Storage bucket for evidence photos and reports
GCS_BUCKET_NAME=inspectai-evidence

# ============================================
# APPLICATION
# ============================================

# Server port (Cloud Run uses 8080)
PORT=8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================
# DEVELOPMENT FLAGS
# ============================================

# Set to "true" to use in-memory stores instead of Firestore/GCS
# Useful for local development without GCP credentials
USE_MEMORY_STORE=true
